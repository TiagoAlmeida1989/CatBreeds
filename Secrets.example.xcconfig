// Secrets.example.xcconfig
// Copy this file to Secrets.xcconfig and fill in your key.
// Get your API key at https://thecatapi.com/
//
// In Xcode: Project → Info → Configurations → set Secrets.xcconfig for Debug and Release
// (both at project level and app target level).
//
// Non-secret configuration (base URL, etc.) lives in Config.xcconfig (committed).
// Secrets.xcconfig includes it automatically via #include — do not remove that line.
//
// NOTE: URLs in xcconfig must use $() to escape //, otherwise it is parsed as a comment.
// Example: https:$()/api.example.com  →  resolves to https://api.example.com

#include "Config.xcconfig"

CAT_API_KEY = your_cat_api_key_here
